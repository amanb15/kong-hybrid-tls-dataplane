ENV=uat

# --- GCP / Cluster (PERSONAL account) ---
PROJECT_ID=kong-gke-495314
CLUSTER_NAME=kong-cluster2
LOCATION_TYPE=zone
LOCATION=us-central1-b
CONNECT_MODE=standard

# --- Namespaces ---
OPERATOR_NAMESPACE=kong-operator
NAMESPACE=uat

# --- Image (Data Plane) ---
IMAGE_PATH=kong/kong-gateway:3.15

# --- Gateway API object names (GatewayClass is cluster-scoped, must be unique) ---
GATEWAY_CLASS_NAME=kong-uat-hybrid
GATEWAY_CONFIG_NAME=kong-config-uat-hybrid
GATEWAY_NAME=kong

# --- Hybrid mode / TLS auth (no PAT/SAT, no KonnectAPIAuthConfiguration) ---
CLUSTER_CERT_SECRET_NAME=kong-cluster-cert
CLUSTER_CONTROL_PLANE=96200d2b61.in.cp.konghq.com:443
CLUSTER_SERVER_NAME=96200d2b61.in.cp.konghq.com
CLUSTER_TELEMETRY_ENDPOINT=96200d2b61.in.tp.konghq.com:443
CLUSTER_TELEMETRY_SERVER_NAME=96200d2b61.in.tp.konghq.com

# --- Ingress exposure ---
INGRESS_SERVICE_TYPE=ClusterIP

# --- Data Plane sizing ---
AUTOSCALING_ENABLED=false
DATAPLANE_REPLICAS=1
DATAPLANE_CPU_REQUEST=250m
DATAPLANE_CPU_LIMIT=500m
DATAPLANE_MEMORY_REQUEST=256Mi
DATAPLANE_MEMORY_LIMIT=512Mi

# --- Operator install ---
OPERATOR_IMAGE_TAG=2.2
OPERATOR_REPLICAS=1
CERT_MANAGER_ENABLED=false
